{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/sync-fixtures",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/update-live",
      "schedule": "* * * * *"
    }
  ]
}
